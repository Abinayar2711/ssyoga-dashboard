# Copy to .streamlit/secrets.toml (git-ignored) for local gsheet testing,
# or paste into Streamlit Cloud → Settings → Secrets for production.
#
# --- Google sign-in gate (st.login). Required, or the app shows a login error. ---
# The [auth] header must sit at column 1. Same OAuth client as the other report
# apps; only redirect_uri and cookie_secret differ per app.
[auth]
redirect_uri = "https://<this-app>.streamlit.app/oauth2callback"   # localhost:8501 locally
cookie_secret = "<long random hex, unique per app>"
client_id = "<shared OAuth client id>"
client_secret = "<shared OAuth client secret>"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# --- Google Sheet reader (only when data_source = "gsheet") ---
# From your Google Cloud service-account JSON key:
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "ssyoga-dashboard@your-project.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
